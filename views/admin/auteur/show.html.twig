{% extends 'admin/base.html.twig' %}

{% block title %}Auteur{% endblock %}

{% block body %}
    <h1>Auteur</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ auteur.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ auteur.nom }}</td>
            </tr>
            <tr>
                <th>Prenom</th>
                <td>{{ auteur.prenom }}</td>
            </tr>
            <tr>
                <th>Biographie</th>
                <td>{{ auteur.biographie }}</td>
            </tr>
            <tr>
                <th>Naissance</th>
                <td>{{ auteur.naissance ? auteur.naissance|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Deces</th>
                <td>{{ auteur.deces ? auteur.deces|date('Y-m-d') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_admin_auteur_index') }}">back to list</a>

    <a href="{{ path('app_admin_auteur_edit', {'id': auteur.id}) }}">edit</a>

    {{ include('admin/auteur/_delete_form.html.twig') }}
{% endblock %}
